# Local machine example
# Loaded after `.env`, so values here override local defaults when both exist.

APP_ENV=development
PORT=4000
VULN_RADAR_API_TOKEN=replace-with-local-dev-token
CORS_ORIGIN=http://localhost:3000
FRONTEND_ORIGIN=http://localhost:3000
INGEST_LOOKBACK_HOURS=24
INGEST_SCHEDULER_ENABLED=true
INGEST_SYNC_INTERVAL_MINUTES=1440
INGEST_SYNC_ON_STARTUP=false
NVD_API_KEY=

# Local PostgreSQL example
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/vuln_radar

# If you want to test against Railway from local, use the public reachable direct URL here.
# DIRECT_URL=postgresql://<user>:<password>@<public-host>:<port>/<db>?sslmode=require
# SHADOW_DATABASE_URL=postgresql://<user>:<password>@<public-host>:<port>/<shadow-db>?sslmode=require
