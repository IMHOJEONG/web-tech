# Railway Variables reference
# Do not upload this file to Railway. Copy these keys into the Railway dashboard Variables UI.

APP_ENV=production
PORT=4000
VULN_RADAR_API_TOKEN=replace-with-production-token
CORS_ORIGIN=https://your-frontend-host.example.com
FRONTEND_ORIGIN=https://your-frontend-host.example.com
INGEST_LOOKBACK_HOURS=24
INGEST_SCHEDULER_ENABLED=true
INGEST_SYNC_INTERVAL_MINUTES=1440
INGEST_SYNC_ON_STARTUP=false
NVD_API_KEY=

# Prefer Railway-provided database variables for deployed services.
# If DIRECT_URL is set, the backend uses it before DATABASE_URL.
DATABASE_URL=postgresql://<railway-runtime-db-url>
DIRECT_URL=postgresql://<railway-runtime-direct-url>
SHADOW_DATABASE_URL=postgresql://<railway-shadow-db-url>
