# Base local example
# Prefer copying this file into `.env.local` for machine-specific overrides.
# Railway production/staging should use dashboard Variables instead of an env file.

APP_ENV=development
PORT=4000
VULN_RADAR_API_TOKEN=
CORS_ORIGIN=http://localhost:3000
FRONTEND_ORIGIN=http://localhost:3000
INGEST_LOOKBACK_HOURS=24
INGEST_SCHEDULER_ENABLED=true
INGEST_SYNC_INTERVAL_MINUTES=60
INGEST_SYNC_ON_STARTUP=false
NVD_API_KEY=
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/vuln_radar
