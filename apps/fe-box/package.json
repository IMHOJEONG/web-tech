{
  "name": "fe-box",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "NODE_OPTIONS='--import ./instrument.server.mjs' vite dev --port 3000",
    "build": "vite build && cp instrument.server.mjs .output/server",
    "preview": "vite preview",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "format": "biome format",
    "lint": "biome lint",
    "check": "biome check",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "post-cta-init": "npx create-db@latest",
    "db:generate": "dotenv -e .env.local -- prisma generate",
    "db:push": "dotenv -e .env.local -- prisma db push",
    "db:migrate": "dotenv -e .env.local -- prisma migrate dev",
    "db:studio": "dotenv -e .env.local -- prisma studio",
    "db:seed": "dotenv -e .env.local -- prisma db seed",
    "start": "node --import ./.output/server/instrument.server.mjs .output/server/index.mjs"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "catalog:fe-box",
    "@prisma/adapter-pg": "catalog:fe-box",
    "@prisma/client": "catalog:fe-box",
    "@sentry/tanstackstart-react": "catalog:fe-box",
    "@storybook/react-vite": "catalog:fe-box",
    "@tailwindcss/vite": "catalog:fe-box",
    "@tanstack/ai": "catalog:fe-box",
    "@tanstack/ai-anthropic": "catalog:fe-box",
    "@tanstack/ai-client": "catalog:fe-box",
    "@tanstack/ai-react": "catalog:fe-box",
    "@tanstack/react-ai-devtools": "catalog:fe-box",
    "@tanstack/react-devtools": "catalog:fe-box",
    "@tanstack/react-query": "catalog:fe-box",
    "@tanstack/react-query-devtools": "catalog:fe-box",
    "@tanstack/react-router": "catalog:fe-box",
    "@tanstack/react-router-devtools": "catalog:fe-box",
    "@tanstack/react-router-ssr-query": "catalog:fe-box",
    "@tanstack/react-start": "catalog:fe-box",
    "@tanstack/react-store": "catalog:fe-box",
    "@tanstack/router-plugin": "catalog:fe-box",
    "@tanstack/store": "catalog:fe-box",
    "@trpc/client": "catalog:fe-box",
    "@trpc/server": "catalog:fe-box",
    "@trpc/tanstack-react-query": "catalog:fe-box",
    "class-variance-authority": "catalog:fe-box",
    "clsx": "catalog:",
    "highlight.js": "catalog:fe-box",
    "lucide-react": "catalog:",
    "nitro": "catalog:fe-box",
    "prisma": "catalog:fe-box",
    "react": "catalog:",
    "react-dom": "catalog:",
    "storybook": "catalog:fe-box",
    "streamdown": "catalog:fe-box",
    "superjson": "catalog:fe-box",
    "tailwind-merge": "catalog:fe-box",
    "tailwindcss": "catalog:",
    "tw-animate-css": "catalog:",
    "vite-tsconfig-paths": "catalog:fe-box",
    "zod": "catalog:fe-box"
  },
  "devDependencies": {
    "@biomejs/biome": "2.2.4",
    "@tanstack/devtools-event-client": "catalog:fe-box",
    "@tanstack/devtools-vite": "catalog:fe-box",
    "@testing-library/dom": "catalog:fe-box",
    "@testing-library/react": "catalog:fe-box",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@vitejs/plugin-react": "catalog:fe-box",
    "dotenv-cli": "catalog:fe-box",
