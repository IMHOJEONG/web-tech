{
    "extends": "@web-tech/typescript-config/nextjs.json",
    "compilerOptions": {
        "plugins": [
            {
                "name": "next"
            }
        ],
        "paths": {
            "~/*": ["./*"],
            "@/*": ["../../packages/ui/*"]
        }
    },
    "include": [
        "**/*.ts",
        "**/*.tsx",
        ".next/types/**/*.ts",
        "tailwind.config.js"
    ],
    "exclude": ["node_modules"]
}
