{
    "extends": "@web-tech/typescript-config/nextjs",
    "compilerOptions": {
        "plugins": [
            {
                "name": "next"
            }
        ],
        "paths": {
            "~/*": ["./*"]
        }
    },
    "include": [
        "**/*.ts",
        "**/*.tsx",
        ".next/types/**/*.ts",
        "tailwind.config.js",
        "d.ts"
    ],
    "exclude": ["node_modules"]
}
