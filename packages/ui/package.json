{
  "name": "@web-tech/ui",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.build.json",
    "dev": "rm -rf dist && tsc -p tsconfig.build.json --watch --preserveWatchOutput",
    "lint": "eslint \"**/*.{ts,tsx}\" --max-warnings 0",
    "generate:component": "turbo gen react-component"
  },
  "devDependencies": {
    "@eslint/eslintrc": "catalog:",
    "@eslint/js": "catalog:",
    "@turbo/gen": "^2.8.8",
    "@types/eslint": "^9.6.1",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@web-tech/eslint-config": "workspace:*",
    "@web-tech/tailwind-config": "workspace:*",
    "@web-tech/typescript-config": "workspace:*",
    "eslint": "catalog:",
    "typescript": "catalog:"
  },
  "dependencies": {
    "@emotion/react": "catalog:ui",
    "@emotion/styled": "catalog:ui",
    "@radix-ui/react-collapsible": "catalog:ui",
    "@radix-ui/react-dialog": "catalog:ui",
    "@radix-ui/react-icons": "catalog:ui",
    "@radix-ui/react-separator": "catalog:ui",
    "@radix-ui/react-slot": "catalog:ui",
    "@radix-ui/react-tooltip": "catalog:ui",
    "@tailwindcss/postcss": "catalog:",
    "class-variance-authority": "catalog:ui",
    "clsx": "catalog:",
    "cmdk": "catalog:ui",
    "dayjs": "catalog:ui",
    "lucide-react": "catalog:",
    "motion": "catalog:ui",
    "postcss": "catalog:",
    "react": "catalog:",
    "react-icons": "^5.5.0",
    "recharts": "catalog:ui",
    "tailwind-merge": "catalog:ui",
    "tailwindcss": "catalog:",
    "tw-animate-css": "catalog:"
  },
  "exports": {
    "./lib/*": {
      "types": "./dist/lib/*.d.ts",
      "default": "./dist/lib/*.js"
    },
    "./components/*": {
      "types": "./dist/components/ui/*.d.ts",
      "default": "./dist/components/ui/*.js"
    }
  }
}
