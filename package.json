{
  "name": "web-tech",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "test": "turbo test"
  },
  "devDependencies": {
    "@eslint/compat": "^1.3.0",
    "eslint": "^9.29.0",
    "prettier": "^3.5.3",
    "simple-git-hooks": "^2.13.0",
    "turbo": "^2.5.4",
    "typescript": "^5.8.3"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm lint && pnpm format && echo 'ok'",
    "pre-push": "pnpm lint && pnpm format",
    "preserveUnused": [
      "commit-msg"
    ]
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "pnpm@9.15.1+sha512.1acb565e6193efbebda772702950469150cf12bcc764262e7587e71d19dc98a423dff9536e57ea44c49bdf790ff694e83c27be5faa23d67e0c033b583be4bfcf"
}
