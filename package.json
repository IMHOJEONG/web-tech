{
  "name": "web-tech",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "dev:web": "turbo dev --filter=web",
    "dev:docs": "turbo dev --filter=docs",
    "start:web": "turbo start --filter=web",
    "start:docs": "turbo start --filter=docs",
    "dev:api": "turbo dev --filter=api",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "rm:pnpm-store": "rm -rf \"$(pnpm store path)\"",
    "test": "turbo test",
    "vercel:deploy:web": "vercel --cwd apps/web && vercel deploy",
    "vercel:deploy:docs": "vercel --cwd apps/docs && vercel deploy",
    "update:simple-git-hooks": "npx simple-git-hooks"
  },
  "devDependencies": {
    "@eslint/compat": "^1.4.1",
    "eslint": "^9.39.4",
    "prettier": "^3.8.1",
    "simple-git-hooks": "^2.13.1",
    "turbo": "^2.9.8",
    "typescript": "^6.0.3"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm format && echo 'ok'",
    "pre-push": "pnpm format",
    "preserveUnused": [
      "commit-msg"
    ]
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "pnpm@11.0.4+sha512.0a397165007a014ed52919a61e5f46c48b9bca88404c303ecaecc63f62def563898d3c6b8a5d5ea5811eb398cfe03ab05da1a5ce963f126d5ead4c02f93b83c3"
}
