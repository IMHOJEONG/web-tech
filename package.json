{
  "name": "web-tech",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "dev:web": "turbo dev --filter=web",
    "dev:docs": "turbo dev --filter=docs",
    "start:web": "turbo start --filter=web",
    "start:docs": "turbo start --filter=docs",
    "dev:api": "turbo dev --filter=api",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "test": "turbo test",
    "vercel:deploy:web": "vercel --cwd apps/web && vercel deploy",
    "vercel:deploy:docs": "vercel --cwd apps/docs && vercel deploy",
    "update:simple-git-hooks": "npx simple-git-hooks"
  },
  "devDependencies": {
    "@eslint/compat": "^1.3.2",
    "eslint": "^9.34.0",
    "prettier": "^3.6.2",
    "simple-git-hooks": "^2.13.1",
    "turbo": "^2.5.6",
    "typescript": "^5.9.2"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm format && echo 'ok'",
    "pre-push": "pnpm format",
    "preserveUnused": [
      "commit-msg"
    ]
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "pnpm@9.15.1+sha512.1acb565e6193efbebda772702950469150cf12bcc764262e7587e71d19dc98a423dff9536e57ea44c49bdf790ff694e83c27be5faa23d67e0c033b583be4bfcf",
  "dependencies": {
    "vercel": "^47.0.5"
  },
  "pnpm": {
    "overrides": {
      "glob": ">=11.1.0",
      "tmp": ">=0.2.4",
      "undici": ">=5.29.0",
      "esbuild": ">=0.25.0",
      "js-yaml": ">=4.1.1",
      "body-parser": ">=2.2.1",
      "mdast-util-to-hast": ">=13.2.1",
      "path-to-regexp": ">=6.3.0"
    }
  }
}
