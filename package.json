{
  "name": "web-tech",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "dev:web": "turbo dev --filter=web",
    "dev:docs": "turbo dev --filter=docs",
    "start:web": "turbo start --filter=web",
    "start:docs": "turbo start --filter=docs",
    "dev:api": "turbo dev --filter=api",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "rm:pnpm-store": "rm -rf \"$(pnpm store path)\"",
    "test": "turbo test",
    "vercel:deploy:web": "vercel --cwd apps/web && vercel deploy",
    "vercel:deploy:docs": "vercel --cwd apps/docs && vercel deploy",
    "update:simple-git-hooks": "npx simple-git-hooks"
  },
  "devDependencies": {
    "@eslint/compat": "^1.4.1",
    "eslint": "^9.39.4",
    "prettier": "^3.8.1",
    "simple-git-hooks": "^2.13.1",
    "turbo": "^2.9.8",
    "typescript": "^6.0.3"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm format && echo 'ok'",
    "pre-push": "pnpm format",
    "preserveUnused": [
      "commit-msg"
    ]
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "vercel": "^53.1.0"
  },
  "packageManager": "pnpm@10.33.2+sha512.a90faf6feeab71ad6c6e57f94e0fe1a12f5dcc22cd754db40ae9593eb6a3e0b6b12e3540218bb37ae083404b1f2ce6db2a4121e979829b4aff94b99f49da1cf8"
}
