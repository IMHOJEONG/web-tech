{
  "name": "web-tech",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "check:vuln-radar:dev": "bash ./scripts/check-vuln-radar-dev.sh",
    "dev": "turbo dev",
    "dev:vuln-radar": "turbo dev --filter=vuln-radar",
    "dev:vuln-radar:full": "turbo dev --filter=vuln-radar --filter=vuln-radar-backend",
    "dev:docs": "turbo dev --filter=docs",
    "start:vuln-radar": "turbo start --filter=vuln-radar",
    "start:vuln-radar:full": "turbo start --filter=vuln-radar --filter=vuln-radar-backend",
    "start:docs": "turbo start --filter=docs",
    "dev:vuln-radar-backend": "turbo dev --filter=vuln-radar-backend",
    "start:vuln-radar-backend": "turbo start --filter=vuln-radar-backend",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "rm:pnpm-store": "rm -rf \"$(pnpm store path)\"",
    "test": "turbo test",
    "vercel:deploy:vuln-radar": "vercel --cwd apps/vuln-radar && vercel deploy",
    "vercel:deploy:docs": "vercel --cwd apps/docs && vercel deploy",
    "update:simple-git-hooks": "npx simple-git-hooks"
  },
  "devDependencies": {
    "@eslint/compat": "^1.4.1",
    "eslint": "^9.39.4",
    "prettier": "^3.8.1",
    "simple-git-hooks": "^2.13.1",
    "turbo": "^2.9.8",
    "typescript": "^6.0.3"
  },
  "simple-git-hooks": {
    "pre-commit": "./scripts/pnpmw.sh format && echo 'ok'",
    "pre-push": "./scripts/pnpmw.sh format",
    "preserveUnused": [
      "commit-msg"
    ]
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "pnpm@11.0.4+sha512.0a397165007a014ed52919a61e5f46c48b9bca88404c303ecaecc63f62def563898d3c6b8a5d5ea5811eb398cfe03ab05da1a5ce963f126d5ead4c02f93b83c3"
}
