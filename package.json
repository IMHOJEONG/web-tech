{
  "name": "web-tech",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "test": "turbo test"
  },
  "devDependencies": {
    "@eslint/compat": "^1.2.5",
    "eslint": "^9.19.0",
    "prettier": "^3.4.2",
    "simple-git-hooks": "^2.11.1",
    "turbo": "^2.3.4",
    "typescript": "^5.7.3"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm lint && pnpm format && echo 'ok'",
    "pre-push": "pnpm lint && pnpm format",
    "preserveUnused": [
      "commit-msg"
    ]
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "pnpm@10.0.0"
}
