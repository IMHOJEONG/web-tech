{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [".next/**", "dist/**", "!.next/cache/**"]
    },
    "test": {
      "dependsOn": ["^build"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "start": {
      "dependsOn": ["build"],
      "cache": false,
      "persistent": true
    }
  },
  "globalEnv": [
    "CLOUDFLARE_API_TOKEN",
    "BETTER_AUTH_SECRET",
    "BETTER_AUTH_URL",
    "BLOG_CONTENT_API_BASE_URL",
    "BLOG_CONTENT_API_BASE_URL_INTERNAL",
    "BLOG_CONTENT_API_BASE_URL_PUBLIC",
    "BLOG_CONTENT_API_TOKEN",
    "BLOG_CONTENT_API_POSTS_PATH",
    "BLOG_CONTENT_MARKDOWN_BASE_URL",
    "BLOG_CONTENT_MARKDOWN_BASE_URL_INTERNAL",
    "BLOG_CONTENT_MARKDOWN_BASE_URL_PUBLIC",
    "BLOG_CONTENT_MARKDOWN_PATH_PREFIX",
    "BLOG_CONTENT_REVALIDATE_SECONDS",
    "BLOG_CONTENT_ASSET_BASE_URL",
    "BLOG_CONTENT_ASSET_BASE_URL_INTERNAL",
    "BLOG_CONTENT_ASSET_BASE_URL_PUBLIC",
    "ENABLE_EXPERIMENTAL_COREPACK"
  ]
}
